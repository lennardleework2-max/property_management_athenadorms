{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "api/*.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/((?!public/).*)",
      "dest": "/api/index.php"
    }
  ]
}
